interface Exam {
    double percentCal();
}

class Student {
    String name;
    int rollNo;
    double marks1, marks2;

    Student(String name, int roll, double m1, double m2) {
        this.name = name; rollNo = roll; marks1 = m1; marks2 = m2;
    }

    void show() {
        System.out.println("Name: " + name + ", Roll No: " + rollNo +
            ", Marks1: " + marks1 + ", Marks2: " + marks2);
    }
}

class Result extends Student implements Exam {
    double per;

    Result(String name, int roll, double m1, double m2) {
        super(name, roll, m1, m2);
        this.per = percentCal();
    }

    public double percentCal() {
        return (marks1 + marks2) / 2;
    }

    void display() {
        show();
        System.out.println("Percentage: " + per + "%");
    }
}

public class ResultProgram {
    public static void main(String[] args) {
        Result r = new Result("John", 301, 85, 90);
        r.display();
    }
}
