interface Mango {
    void display();
}

class Winter implements Mango {
    public void display() {
        System.out.println("Mango in Winter: Not available (off-season).");
    }
}

class Summer implements Mango {
    public void display() {
        System.out.println("Mango in Summer: Fully ripe and available!");
    }
}

public class MangoProgram {
    public static void main(String[] args) {
        Mango w = new Winter();
        Mango s = new Summer();
        w.display();
        s.display();
    }
}
